@model List<GuitarStore.Models.CartItem>
    @{
    ViewData["Title"] = "Cart";
    var total = Model.Sum(item => item.Price * item.Quantity);
    }

    <div class="d-flex align-items-center mb-4 gap-2">
        <i class="bi bi-cart3 fs-4"></i>
        <h2 class="mb-0 fw-bold">Your Cart</h2>
    </div>

    @if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size: 4rem; color: #dee2e6;"></i>
        <h5 class="mt-3 text-muted">Your cart is empty.</h5>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-dark mt-3 px-4">
            Browse Catalog
        </a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            @foreach (var item in Model)
            {
            <div class="card border-0 shadow-sm mb-3 rounded-3">
                <div class="card-body">
                    <div class="row align-items-center g-3">
                        <div class="col-auto">
                            <img src="@item.ImageUrl" alt="@item.Brand"
                                 style="width:90px; height:70px; object-fit:cover; border-radius:8px;"
                                 onerror="this.src='https://placehold.co/90x70/1a1a2e/ffffff?text=Guitar'" />
                        </div>
                        <div class="col">
                            <h6 class="fw-bold mb-0">@item.Brand</h6>
                            <small class="text-muted">@item.Price.ToString("C") each</small>
                        </div>
                        <div class="col-auto d-flex align-items-center gap-2">
                            <form asp-controller="Cart" asp-action="Decrease" method="post">
                                <input type="hidden" name="id" value="@item.GuitarID" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary" style="width:32px; height:32px; padding:0;">−</button>
                            </form>
                            <span class="fw-bold mx-1" style="min-width:20px; text-align:center;">@item.Quantity</span>
                            <form asp-controller="Cart" asp-action="Increase" method="post">
                                <input type="hidden" name="id" value="@item.GuitarID" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary" style="width:32px; height:32px; padding:0;">+</button>
                            </form>
                        </div>
                        <div class="col-auto text-end">
                            <span class="fw-bold">@((item.Price * item.Quantity).ToString("C"))</span>
                        </div>
                        <div class="col-auto">
                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                <input type="hidden" name="id" value="@item.GuitarID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 sticky-top" style="top: 20px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Order Summary</h5>
                    @foreach (var item in Model)
                    {
                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">@item.Brand x @item.Quantity</span>
                        <span>@((item.Price * item.Quantity).ToString("C"))</span>
                    </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Total</span>
                        <span>@total.ToString("C")</span>
                    </div>
                    <a asp-controller="Cart" asp-action="Checkout" class="btn btn-dark w-100 mb-2">
                        Proceed to Checkout
                    </a>
                    <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary w-100 btn-sm">
                        Continue Shopping
                    </a>
                </div>
            </div>
        </div>
    </div>
}
