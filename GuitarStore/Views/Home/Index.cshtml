@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="rounded-4 p-5 text-white mb-5" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #e63946 100%); min-height: 380px; display:flex; align-items:center;">
    <div class="row w-100 align-items-center">
        <div class="col-md-7">
            <p class="text-uppercase fw-semibold mb-2" style="color: #e63946; letter-spacing: 2px; font-size: 0.85rem;">Welcome to GuitarStore</p>
            <h1 class="display-4 fw-bold mb-3">The Sound You've Been Looking For</h1>
            <p class="opacity-75 mb-4 fs-5">Explore our handpicked collection of electric, acoustic and classical guitars from the world's finest brands.</p>
            <div class="d-flex gap-3">
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-danger px-4 py-2 fw-semibold">
                    Shop Now
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light px-4 py-2">
                    Create Account
                </a>
            </div>
        </div>
        <div class="col-md-5 text-end d-none d-md-block">
            <i class="bi bi-music-note-beamed" style="font-size: 12rem; opacity: 0.08;"></i>
        </div>
    </div>
</div>

<!-- Features Row -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-3 h-100 p-4 text-center">
            <i class="bi bi-shield-check fs-1 mb-3" style="color: #e63946;"></i>
            <h5 class="fw-bold">Quality Guaranteed</h5>
            <p class="text-muted small mb-0">Every guitar is sourced from verified manufacturers and inspected before listing.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-3 h-100 p-4 text-center">
            <i class="bi bi-truck fs-1 mb-3" style="color: #e63946;"></i>
            <h5 class="fw-bold">Fast Shipping</h5>
            <p class="text-muted small mb-0">Orders are packed and shipped within 24 hours with full tracking provided.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-3 h-100 p-4 text-center">
            <i class="bi bi-headset fs-1 mb-3" style="color: #e63946;"></i>
            <h5 class="fw-bold">Expert Support</h5>
            <p class="text-muted small mb-0">Our guitar specialists are available 7 days a week to help you find your perfect instrument.</p>
        </div>
    </div>
</div>

<!-- Categories Section -->
<div class="mb-5">
    <h3 class="fw-bold mb-4">Shop by Category</h3>
    <div class="row g-4">
        <div class="col-md-4">
            <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="1" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-3 text-white text-center p-5" style="background: linear-gradient(135deg, #1a1a2e, #e63946);">
                    <i class="bi bi-lightning-charge fs-1 mb-2"></i>
                    <h5 class="fw-bold mb-0">Electric</h5>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="2" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-3 text-white text-center p-5" style="background: linear-gradient(135deg, #16213e, #533483);">
                    <i class="bi bi-music-note fs-1 mb-2"></i>
                    <h5 class="fw-bold mb-0">Acoustic</h5>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="3" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-3 text-white text-center p-5" style="background: linear-gradient(135deg, #0f3460, #4a7c59);">
                    <i class="bi bi-vinyl fs-1 mb-2"></i>
                    <h5 class="fw-bold mb-0">Classical</h5>
                </div>
            </a>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="card border-0 rounded-4 text-white text-center p-5 mb-4" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
    <h3 class="fw-bold mb-2">Ready to find your sound?</h3>
    <p class="opacity-75 mb-4">Join thousands of musicians who trust GuitarStore for their instruments.</p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-danger px-4">Browse All Guitars</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light px-4">Sign Up Free</a>
    </div>
</div>