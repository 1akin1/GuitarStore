@model GuitarStore.Models.Guitar
@{
    Layout = null; // No layout, full-screen image
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@Model.Brand</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            background-color: black;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        img {
            max-width: 100%;
            max-height: 100%;
        }
    </style>
</head>
<body>
    <img src="@Model.ImageUrl" alt="@Model.Brand" />
</body>
</html>
